.vs/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Docker
.dockerignore

# OS generated files
.DS_Store
Thumbs.db

# Azure CLI config files
.azure/

# Editor directories and files
*.local
